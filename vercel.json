{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/docs",        "dest": "api/index.py" },
    { "src": "/openapi.json","dest": "api/index.py" },
    { "src": "/auth/(.*)",   "dest": "api/index.py" },
    { "src": "/couples/(.*)", "dest": "api/index.py" },
    { "src": "/telegram/(.*)", "dest": "api/index.py" },
    { "src": "/whatsapp/(.*)", "dest": "api/index.py" },
    { "src": "/(.*)",        "dest": "frontend/dist/$1" }
  ]
}
