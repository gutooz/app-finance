{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/docs", "dest": "api/index.py" },
    { "src": "/openapi.json", "dest": "api/index.py" },
    { "src": "/auth/(.*)", "dest": "api/index.py" },
    { "src": "/couples/(.*)", "dest": "api/index.py" },
    { "src": "/telegram/(.*)", "dest": "api/index.py" },
    { "src": "/whatsapp/(.*)", "dest": "api/index.py" },
    { "src": "/admin/stats", "dest": "api/index.py" },
    { "src": "/assets/(.*)", "dest": "frontend/assets/$1" },
    { "src": "/favicon.svg", "dest": "frontend/favicon.svg" },
    { "src": "/icons.svg", "dest": "frontend/icons.svg" },
    { "src": "/(.*)", "dest": "frontend/index.html" }
  ]
}
