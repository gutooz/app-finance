{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/docs", "destination": "/api/index.py" },
    { "source": "/openapi.json", "destination": "/api/index.py" },
    { "source": "/auth/:path*", "destination": "/api/index.py" },
    { "source": "/couples/:path*", "destination": "/api/index.py" },
    { "source": "/telegram/:path*", "destination": "/api/index.py" },
    { "source": "/whatsapp/:path*", "destination": "/api/index.py" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
