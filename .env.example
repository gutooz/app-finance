# Copie este arquivo para .env e preencha os valores

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/couple_finance?retryWrites=true&w=majority

# JWT
JWT_SECRET=troque-por-uma-string-aleatoria-longa

# Telegram Bot
BOT_TOKEN=SEU_BOT_TOKEN
TELEGRAM_BOT_USERNAME=SEU_BOT_USERNAME
TELEGRAM_WEBHOOK_SECRET=uma-string-secreta-para-o-webhook

# URLs (ajuste para producao)
FRONTEND_URL=https://seu-app.vercel.app
API_BASE_URL=https://seu-app.vercel.app

# SMTP (envio de e-mail de redefinicao de senha)
# Gmail: gere uma "senha de app" em myaccount.google.com/apppasswords
# (nunca use a senha normal da conta; nunca cole a senha de app aqui neste arquivo de exemplo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app-de-16-digitos
SMTP_FROM=seu-email@gmail.com

# WhatsApp / Evolution API (opcional)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=fincouple
WHATSAPP_BUSINESS_NUMBER=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_SEND_REPLIES=true

# Pluggy / Open Finance
PLUGGY_CLIENT_ID=SEU_CLIENT_ID
PLUGGY_CLIENT_SECRET=SEU_CLIENT_SECRET
PLUGGY_BASE_URL=https://api.pluggy.ai
PLUGGY_WEBHOOK_SECRET=uma-string-secreta-para-o-webhook-pluggy

# Assistente IA (Ollama)
# Local:     ollama serve  ->  http://localhost:11434
# Producao:  aponte para um servidor Ollama hospedado (VPS/GPU)
# O modelo PRECISA suportar tools/function-calling: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=120

# Transcricao de audio (Whisper local, usado pelas mensagens de voz do Telegram)
# Local:     uvicorn whisper_server.app:app --port 8090
# Producao:  hospede na mesma VPS do Ollama (nao roda na Vercel/serverless)
WHISPER_BASE_URL=http://localhost:8090
WHISPER_MODEL=small
WHISPER_TIMEOUT=60
